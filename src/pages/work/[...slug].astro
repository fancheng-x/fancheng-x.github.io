---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { href } from '../../utils/url';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects
    .filter((p) => p.data.hasCaseStudy)
    .map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const d = project.data;
const { Content } = await render(project);

const catLabel: Record<string, string> = {
  product: 'Product Analytics', operations: 'Operations', simulation: 'Simulation',
  ai: 'AI Workflows', risk: 'Risk Analytics',
};
---
<Base title={`${d.title} — Valeria Xia`} description={d.businessProblem}>
  <article>
    <!-- case-study header -->
    <header class="cs-head">
      <div class="shell">
        <a class="back" href={href('/work')}>← Selected Work</a>
        <div class="ptags">
          {d.categories.map((c) => <span class="ptag">{catLabel[c]}</span>)}
          <span class="ptag alt">{d.year}</span>
        </div>
        <h1 class="display cs-title">{d.title}</h1>
        <p class="cs-sub">{d.subtitle}</p>

        <div class="meta-grid">
          <div class="m"><span class="mk">Role</span><span class="mv">{d.role}</span></div>
          {d.collaborators && <div class="m"><span class="mk">Team</span><span class="mv">{d.collaborators}</span></div>}
          <div class="m"><span class="mk">Tools</span><span class="mv">{d.tools.join(', ')}</span></div>
          <div class="m impact-m">
            <span class="mk">Impact</span>
            <span class:list={['mv', 'strong', { ph: d.impactPlaceholder }]}>{d.impactValue}</span>
          </div>
        </div>
      </div>
    </header>

    {d.confidentialityNote && (
      <div class="shell"><p class="confidential">🔒 {d.confidentialityNote}</p></div>
    )}

    <!-- MDX body -->
    <div class="shell">
      <div class="prose">
        <Content />
      </div>
      <div class="cs-foot">
        <a class="btn sec" href={href('/work')}>← All projects</a>
        {d.repositoryUrl && <a class="btn sec" href={d.repositoryUrl} target="_blank" rel="noopener">View code ↗</a>}
        <a class="btn pri" href="mailto:f4xia@ucsd.edu">Discuss this work</a>
      </div>
    </div>
  </article>
</Base>

<style>
  .cs-head { padding: 46px 0 40px; border-bottom: 1px solid var(--line); background: var(--surface); }
  .back { font-family: var(--mono); font-size: 13px; color: var(--mut); display: inline-block; margin-bottom: 24px; }
  .back:hover { color: var(--accent); }
  .ptags { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 18px; }
  .ptag {
    font-family: var(--mono); font-size: 11px; letter-spacing: .04em; text-transform: uppercase;
    color: var(--accent-deep); background: var(--accent-tint); padding: 4px 9px; border-radius: 5px;
  }
  .ptag.alt { color: var(--mut); background: transparent; border: 1px solid var(--line-2); }
  .cs-title { font-size: clamp(28px, 4.4vw, 46px); margin-bottom: 14px; max-width: 24ch; }
  .cs-sub { font-family: var(--mono); font-size: 14px; color: var(--mut); margin-bottom: 34px; }

  .meta-grid {
    display: grid; grid-template-columns: repeat(4, auto); gap: 12px 40px;
    padding-top: 24px; border-top: 1px solid var(--line);
  }
  .m { display: flex; flex-direction: column; gap: 4px; }
  .mk { font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--mut); }
  .mv { font-size: 14px; color: var(--ink); max-width: 32ch; }
  .mv.strong { font-weight: 600; }
  .mv.ph { color: var(--amber); font-family: var(--mono); font-size: 13px; }

  .confidential {
    margin: 26px 0 -10px; font-size: 13px; color: var(--mut); font-family: var(--mono);
    background: var(--accent-tint); border: 1px solid var(--line); border-radius: 8px; padding: 10px 14px;
  }

  /* ---- prose (MDX body) ---- */
  .prose { max-width: 68ch; margin: 46px 0 0; font-size: 16.5px; line-height: 1.7; color: var(--ink-2); }
  .prose :global(h2) {
    font-family: var(--serif); font-size: 25px; font-weight: 500; letter-spacing: -.01em;
    color: var(--ink); margin: 48px 0 14px; padding-top: 26px; border-top: 1px solid var(--line);
    text-wrap: balance;
  }
  .prose :global(h2:first-child) { margin-top: 0; padding-top: 0; border-top: none; }
  .prose :global(h3) { font-size: 17px; font-weight: 600; color: var(--ink); margin: 30px 0 10px; }
  .prose :global(p) { margin: 0 0 18px; }
  .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .prose :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 20px; padding-left: 22px; }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(li::marker) { color: var(--accent); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent); padding: 4px 0 4px 20px; margin: 24px 0;
    color: var(--ink); font-family: var(--serif); font-size: 19px; font-style: italic;
  }
  .prose :global(code) {
    font-family: var(--mono); font-size: .86em; background: var(--accent-tint);
    padding: 2px 6px; border-radius: 5px; color: var(--accent-deep);
  }
  .prose :global(hr) { border: 0; height: 1px; background: var(--line); margin: 36px 0; }
  /* placeholder marker used inside case studies for numbers to verify */
  .prose :global(.ph) {
    font-family: var(--mono); font-size: .85em; color: var(--amber);
    background: color-mix(in srgb, var(--amber) 12%, transparent);
    border: 1px dashed var(--amber); padding: 1px 7px; border-radius: 5px; white-space: nowrap;
  }
  /* simple metric row usable in MDX: <div class="metrics">... */
  .prose :global(.metrics) {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 1px;
    background: var(--line); border: 1px solid var(--line); border-radius: 12px; overflow: hidden;
    margin: 26px 0;
  }
  .prose :global(.metrics .metric) { background: var(--surface); padding: 18px 16px; }
  .prose :global(.metrics .n) { font-size: 24px; font-weight: 600; color: var(--accent); font-variant-numeric: tabular-nums; letter-spacing: -.01em; }
  .prose :global(.metrics .k) { font-size: 12.5px; color: var(--mut); margin-top: 4px; line-height: 1.35; }

  .cs-foot { display: flex; gap: 12px; flex-wrap: wrap; margin: 54px 0 20px; padding-top: 30px; border-top: 1px solid var(--line); }

  @media (max-width: 700px) {
    .meta-grid { grid-template-columns: 1fr 1fr; }
    .prose { font-size: 16px; }
  }
</style>

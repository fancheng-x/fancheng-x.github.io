---
import Base from '../layouts/Base.astro';
import { href } from '../utils/url';

const experience = [
  {
    org: 'UCSD Rady MSBA — Capstone',
    role: 'Technical Lead · Global Operations Analytics & Simulation',
    dates: 'Mar – Jun 2026',
    scope: 'Led a client-facing decision-support framework for a global multi-site service network.',
    bullets: [
      'Built a two-stage optimization + Monte Carlo simulation pipeline in Python to model capacity, backlog, routing, and demand uncertainty under real constraints.',
      'Validated outputs against confidential client operating data in a secure environment.',
      'Presented recommendations to senior and executive stakeholders — framed around speed, capacity, and service-reliability tradeoffs.',
    ],
    tools: ['Python', 'Optimization', 'Monte Carlo', 'Stakeholder comms'],
  },
  {
    org: 'KPMG — Shanghai, China',
    role: 'Risk Consulting Intern',
    dates: 'Mar – May 2024',
    scope: 'Supported risk advisory for healthcare and life-sciences clients.',
    bullets: [
      'Analyzed 10+ years of healthcare data with statistical and predictive methods to generate risk insights.',
      'Ran fraud and credit-risk analyses in Python and Excel, translating results into actionable client recommendations.',
      'Synthesized quantitative analysis and expert interviews into 15+ client-facing presentations for non-technical audiences.',
    ],
    tools: ['Python', 'Excel', 'Risk modeling', 'Client presentations'],
  },
  {
    org: 'Guotai Junan Securities — China',
    role: 'Industry Research Assistant (Part-time)',
    dates: 'Jan – Mar 2024',
    scope: 'Non-bank financials research for quarterly investment outlooks.',
    bullets: [
      'Validated data from 42 brokerage firms using Wind to update Q3 non-bank industry reports.',
      'Ran ratio and sensitivity analyses across 40+ financial statements, improving model accuracy and consistency by 25%.',
      'Delivered analysis on capital-market trends and policy leveraged by 4+ stakeholders.',
    ],
    tools: ['Wind', 'Financial modeling', 'Sensitivity analysis'],
  },
];
---
<Base title="About — Fancheng (Valeria) Xia" description="MS Business Analytics candidate at UC San Diego. From financial research and risk advisory to ML and operations systems that drive decisions.">
  <div class="shell">
    <header class="page-head">
      <p class="eyebrow">About</p>
      <h1 class="display page-title">From risk advisory to machine-learning systems that move decisions.</h1>
    </header>

    <section class="bio">
      <div class="bio-lead">
        <p>
          I'm a <strong>Master of Science in Business Analytics</strong> candidate at
          <strong>UC San Diego's Rady School of Management</strong> (GPA 3.84). I started in financial
          research and risk advisory — at KPMG and Guotai Junan — where I learned that the hardest part
          of analytics isn't the model, it's <strong>framing the right question and getting people to act
          on the answer</strong>.
        </p>
        <p>
          Today I work across analytics, product thinking, operations, and AI-enabled workflows. I build
          simulations, optimization models, and ML systems — then translate them into recommendations that
          senior and technical stakeholders can defend. I'm most useful on <strong>ambiguous, cross-functional
          problems</strong> where the goal is a measurable operational or product outcome, not just a chart.
        </p>
        <p>
          I'm targeting roles in <strong>Product Analytics, Product Operations, and Operations Analytics</strong>,
          starting December 2026.
        </p>
      </div>
      <aside class="bio-side">
        <div class="edu">
          <span class="mk">Education</span>
          <div class="edu-item">
            <b>M.S. Business Analytics</b>
            <span>UC San Diego, Rady School of Management</span>
            <span class="dim">Dec 2026 · GPA 3.84</span>
          </div>
          <div class="edu-item">
            <b>B.A. Business Administration</b>
            <span>Zhongnan University of Economics and Law</span>
            <span class="dim">Wuhan, China · 2024</span>
          </div>
        </div>
        <a class="btn sec" href={href('/resume.pdf')} target="_blank" rel="noopener" style="width:100%;justify-content:center">Download résumé ↓</a>
      </aside>
    </section>

    <section class="section" id="experience">
      <p class="eyebrow">Experience</p>
      <h2 class="sec-title">Where I've done the work.</h2>
      <div class="timeline">
        {experience.map((e) => (
          <div class="tl-item">
            <div class="tl-when"><span>{e.dates}</span></div>
            <div class="tl-body">
              <h3>{e.role}</h3>
              <p class="tl-org">{e.org}</p>
              <p class="tl-scope">{e.scope}</p>
              <ul>{e.bullets.map((b) => <li>{b}</li>)}</ul>
              <div class="tl-tools">{e.tools.map((t) => <span>{t}</span>)}</div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .page-head { padding: 70px 0 30px; }
  .page-title { font-size: clamp(30px, 4.4vw, 46px); max-width: 20ch; }

  .bio { display: grid; grid-template-columns: 1.6fr 1fr; gap: 46px; padding-bottom: 20px; align-items: start; }
  .bio-lead p { font-size: 18px; line-height: 1.7; color: var(--ink-2); margin-bottom: 18px; }
  .bio-lead strong { color: var(--ink); font-weight: 600; }
  .bio-side { display: flex; flex-direction: column; gap: 18px; position: sticky; top: 90px; }
  .edu { background: var(--surface); border: 1px solid var(--line); border-radius: 14px; padding: 22px; display: flex; flex-direction: column; gap: 18px; }
  .mk { font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--mut); }
  .edu-item { display: flex; flex-direction: column; gap: 3px; font-size: 14px; color: var(--ink-2); }
  .edu-item b { color: var(--ink); font-size: 15px; }
  .edu-item .dim { font-family: var(--mono); font-size: 12px; color: var(--mut); }

  .timeline { display: flex; flex-direction: column; }
  .tl-item { display: grid; grid-template-columns: 160px 1fr; gap: 28px; padding: 30px 0; border-top: 1px solid var(--line); }
  .tl-when span { font-family: var(--mono); font-size: 12.5px; color: var(--mut); position: sticky; top: 90px; display: inline-block; }
  .tl-body h3 { font-family: var(--serif); font-size: 21px; font-weight: 500; margin-bottom: 4px; }
  .tl-org { font-size: 14px; color: var(--accent-deep); font-weight: 500; margin-bottom: 10px; }
  .tl-scope { font-size: 15px; color: var(--ink-2); margin-bottom: 12px; }
  .tl-body ul { padding-left: 20px; margin-bottom: 16px; }
  .tl-body li { font-size: 14.5px; line-height: 1.6; color: var(--ink-2); margin-bottom: 7px; }
  .tl-body li::marker { color: var(--accent); }
  .tl-tools { display: flex; flex-wrap: wrap; gap: 7px; }
  .tl-tools span { font-family: var(--mono); font-size: 11.5px; color: var(--mut); border: 1px solid var(--line-2); border-radius: 6px; padding: 4px 9px; }

  @media (max-width: 820px) {
    .bio { grid-template-columns: 1fr; gap: 30px; }
    .bio-side { position: static; }
    .tl-item { grid-template-columns: 1fr; gap: 10px; }
    .tl-when span { position: static; }
  }
</style>

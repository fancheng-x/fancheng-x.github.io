---
const year = 2026;
---
<section class="contact" id="contact">
  <div class="shell contact-in">
    <p class="eyebrow" style="justify-content:center">Contact</p>
    <h2 class="display contact-h">Let's talk about ambiguous problems worth solving.</h2>
    <p class="contact-sub">Open to Product Analyst, Product Operations, and Operations Analytics roles starting December 2026.</p>
    <div class="clinks">
      <a class="btn pri" href="mailto:f4xia@ucsd.edu">Email me</a>
      <a class="btn sec" href="https://www.linkedin.com/in/fanchengxia/" target="_blank" rel="noopener">LinkedIn</a>
      <a class="btn sec" href="https://github.com/fancheng-x" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
  <div class="shell">
    <footer>
      <span>Valeria Xia — San Diego, CA</span>
      <span>© {year} · Built with Astro</span>
    </footer>
  </div>
</section>

<style>
  .contact { border-top: 1px solid var(--line); margin-top: 30px; }
  .contact-in { padding: 74px 0 34px; text-align: center; }
  .contact-h { font-size: clamp(26px, 4vw, 42px); margin-bottom: 16px; }
  .contact-sub { color: var(--mut); font-size: 16px; max-width: 48ch; margin: 0 auto 30px; }
  .clinks { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  footer {
    padding: 24px 0 46px; border-top: 1px solid var(--line);
    color: var(--mut); font-size: 13px; font-family: var(--mono);
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  }
</style>
